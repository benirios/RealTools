# RealTools — environment variables
# Copy this file to .env.local and fill in values from the Supabase dashboard.
# NEVER commit .env.local.

# Supabase — Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — server-only, NEVER NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL — used for auth callback redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Deal Summary — server-only, optional.
# Supported provider in V1: gemini. If no key is set, summaries fail gracefully.
AI_DEAL_SUMMARY_PROVIDER=gemini
AI_DEAL_SUMMARY_MODEL=gemini-3-flash-preview
AI_DEAL_SUMMARY_TEMPERATURE=0.3
GEMINI_API_KEY=your-gemini-api-key
